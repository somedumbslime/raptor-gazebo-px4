<?xml version="1.0" ?>
<sdf version="1.9">
  <world name="raptor_mvp">

    <!-- Если явно перечисляешь system plugins, не рассчитывай на дефолтные -->
    <plugin filename="gz-sim-physics-system"
            name="gz::sim::systems::Physics"/>

	<plugin filename="gz-sim-user-commands-system"
        	name="gz::sim::systems::UserCommands"/>

    <plugin filename="gz-sim-sensors-system"
            name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <scene>
      <ambient>1.0 1.0 1.0</ambient>
      <background>0.8 0.8 0.8</background>
      <grid>false</grid>
    </scene>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.8 0.8 0.8 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.8 0.8 0.8 1</ambient>
            <diffuse>0.8 0.8 0.8 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Цель-заглушка -->
    <model name="target_stub">
      <static>true</static>
      <pose>0 0 0.85 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.25</radius>
              <length>1.7</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.25</radius>
              <length>1.7</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>1 0 0 1</ambient>
            <diffuse>1 0 0 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Отвлекающий объект -->
    <model name="distractor_box">
      <static>true</static>
      <pose>-2 1 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>1 1 1</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>1 1 1</size>
            </box>
          </geometry>
          <material>
            <ambient>0 0 1 1</ambient>
            <diffuse>0 0 1 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="raptor_gimbal">
	  <pose>8 0 2.2 0 0 3.14159</pose>
	  <self_collide>false</self_collide>

	  <!-- База -->
	  <link name="base_link">
	    <gravity>false</gravity>
	    <inertial>
	      <mass>0.3</mass>
	      <inertia>
		<ixx>0.001</ixx>
		<iyy>0.001</iyy>
		<izz>0.001</izz>
		<ixy>0</ixy>
		<ixz>0</ixz>
		<iyz>0</iyz>
	      </inertia>
	    </inertial>
	    <visual name="base_visual">
	      <geometry>
		<box>
		  <size>0.16 0.16 0.08</size>
		</box>
	      </geometry>
	      <material>
		<ambient>0.2 0.2 0.2 1</ambient>
		<diffuse>0.2 0.2 0.2 1</diffuse>
	      </material>
	    </visual>
	  </link>

	  <!-- Yaw-часть -->
	  <link name="yaw_link">
	    <gravity>false</gravity>
	    <inertial>
	      <mass>0.2</mass>
	      <inertia>
		<ixx>0.0005</ixx>
		<iyy>0.0005</iyy>
		<izz>0.0005</izz>
		<ixy>0</ixy>
		<ixz>0</ixz>
		<iyz>0</iyz>
	      </inertia>
	    </inertial>
	    <pose>0 0 0 0 0 0</pose>
	    <visual name="yaw_visual">
	      <geometry>
		<cylinder>
		  <radius>0.04</radius>
		  <length>0.10</length>
		</cylinder>
	      </geometry>
	      <material>
		<ambient>0.0 0.7 0.7 1</ambient>
		<diffuse>0.0 0.7 0.7 1</diffuse>
	      </material>
	    </visual>
	  </link>

	  <!-- Pitch + camera -->
	  <link name="camera_link">
	    <gravity>false</gravity>
	    <inertial>
	      <mass>0.2</mass>
	      <inertia>
		<ixx>0.0005</ixx>
		<iyy>0.0005</iyy>
		<izz>0.0005</izz>
		<ixy>0</ixy>
		<ixz>0</ixz>
		<iyz>0</iyz>
	      </inertia>
	    </inertial>
	    <pose>0.12 0 0 0 0 0</pose>

	    <visual name="camera_body_visual">
	      <geometry>
		<box>
		  <size>0.14 0.08 0.08</size>
		</box>
	      </geometry>
	      <material>
		<ambient>0.1 0.1 0.1 1</ambient>
		<diffuse>0.1 0.1 0.1 1</diffuse>
	      </material>
	    </visual>

	    <sensor name="camera" type="camera">
	      <always_on>1</always_on>
	      <update_rate>20</update_rate>
	      <visualize>false</visualize>
	      <topic>/raptor/camera</topic>
	      <camera>
		<horizontal_fov>1.047</horizontal_fov>
		<image>
		  <width>640</width>
		  <height>480</height>
		</image>
		<clip>
		  <near>0.1</near>
		  <far>100</far>
		</clip>
	      </camera>
	    </sensor>
	  </link>

	  <!-- yaw joint -->
	  <joint name="yaw_joint" type="revolute">
	    <parent>base_link</parent>
	    <child>yaw_link</child>
	    <axis>
	      <xyz>0 0 1</xyz>
	      <limit>
		<lower>-1.4</lower>
		<upper>1.4</upper>
		<effort>10</effort>
		<velocity>2.0</velocity>
	      </limit>
	      <dynamics>
		<damping>0.1</damping>
	      </dynamics>
	    </axis>
	  </joint>

	  <!-- pitch joint -->
	  <joint name="pitch_joint" type="revolute">
	    <parent>yaw_link</parent>
	    <child>camera_link</child>
	    <pose>0.06 0 0 0 0 0</pose>
	    <axis>
	      <xyz>0 1 0</xyz>
	      <limit>
		<lower>-0.7</lower>
		<upper>0.7</upper>
		<effort>10</effort>
		<velocity>2.0</velocity>
	      </limit>
	      <dynamics>
		<damping>0.1</damping>
	      </dynamics>
	    </axis>
	  </joint>

	  <!-- Yaw controller -->
	  <plugin
	    filename="gz-sim-joint-position-controller-system"
	    name="gz::sim::systems::JointPositionController">
	    <joint_name>yaw_joint</joint_name>
	    <topic>/raptor/gimbal/yaw_cmd</topic>
	    <use_velocity_commands>true</use_velocity_commands>
	    <cmd_max>1.2</cmd_max>
	  </plugin>

	  <!-- Pitch controller -->
	  <plugin
	    filename="gz-sim-joint-position-controller-system"
	    name="gz::sim::systems::JointPositionController">
	    <joint_name>pitch_joint</joint_name>
	    <topic>/raptor/gimbal/pitch_cmd</topic>
	    <use_velocity_commands>true</use_velocity_commands>
	    <cmd_max>1.0</cmd_max>
	  </plugin>

	  <!-- Joint states -->
	  <plugin
	    filename="gz-sim-joint-state-publisher-system"
	    name="gz::sim::systems::JointStatePublisher">
	    <topic>/raptor/gimbal/joint_state</topic>
	    <joint_name>yaw_joint</joint_name>
	    <joint_name>pitch_joint</joint_name>
	  </plugin>
	</model>

  </world>
</sdf>
